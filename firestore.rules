rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidPunchRecord(data, userId) {
      return data.keys().hasAll(['userId', 'dateKey', 'records', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.userId == userId &&
             data.dateKey is string && data.dateKey.size() <= 128 &&
             data.records is string && data.records.size() <= 1048576 &&
             data.updatedAt == request.time;
    }

    function isValidLineState(data, userId) {
      return data.keys().hasAll(['userId', 'dateKey', 'lineConfigs', 'activeSplicing', 'lastWashes', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.userId == userId &&
             data.dateKey is string && data.dateKey.size() <= 128 &&
             data.lineConfigs is string && data.lineConfigs.size() <= 1048576 &&
             data.activeSplicing is string && data.activeSplicing.size() <= 1048576 &&
             data.lastWashes is string && data.lastWashes.size() <= 1048576 &&
             data.updatedAt == request.time;
    }

    function isValidPlanSnapshot(data, userId) {
      return data.keys().hasAll(['userId', 'timestamp', 'lineConfigs', 'activeSplicing', 'lastWashes']) &&
             data.keys().size() == 5 &&
             data.userId == userId &&
             data.timestamp is timestamp &&
             data.lineConfigs is string &&
             data.activeSplicing is string &&
             data.lastWashes is string;
    }

    match /users/{userId}/punchRecords/{dateKey} {
      allow get: if isOwner(userId) && isValidId(dateKey);
      allow list: if isOwner(userId) && resource.data.userId == userId;
      allow create: if isOwner(userId) && isValidId(dateKey) && isValidPunchRecord(incoming(), userId);
      allow update: if isOwner(userId) && isValidId(dateKey) && isValidPunchRecord(incoming(), userId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['records', 'updatedAt']);
    }

    match /users/{userId}/lineStates/{dateKey} {
      allow get: if isOwner(userId) && isValidId(dateKey);
      allow list: if isOwner(userId) && resource.data.userId == userId;
      allow create: if isOwner(userId) && isValidId(dateKey) && isValidLineState(incoming(), userId);
      allow update: if isOwner(userId) && isValidId(dateKey) && isValidLineState(incoming(), userId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lineConfigs', 'activeSplicing', 'lastWashes', 'updatedAt']);
    }
    match /users/{userId}/planSnapshots/{snapshotId} {
      allow get: if isOwner(userId) && isValidId(snapshotId);
      allow list: if isOwner(userId) && resource.data.userId == userId;
      allow create: if isOwner(userId) && isValidId(snapshotId) && isValidPlanSnapshot(incoming(), userId);
      allow delete: if isOwner(userId) && isValidId(snapshotId);
    }
  }
}
